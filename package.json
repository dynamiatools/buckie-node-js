{
  "name": "@dynamia-tools/buckie",
  "version": "1.0.0",
  "description": "Standalone filesystem-native file server with a minimal S3-style API for secure server-to-server file operations",
  "keywords": [
    "dynamia",
    "buckie",
    "file-server",
    "storage",
    "s3-like",
    "streaming"
  ],
  "homepage": "https://dynamia.tools",
  "bugs": {
    "url": "https://github.com/dynamiatools/buckie/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dynamiatools/buckie.git",
    "directory": "buckie/node"
  },
  "license": "MIT",
  "author": "Dynamia Soluciones IT SAS",
  "type": "module",
  "bin": {
    "buckie": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli/index.js",
    "rebuild": "tsc -p tsconfig.build.json && chmod +x dist/cli/index.js && echo '✅ buckie actualizado'",
    "dev": "tsx watch src/cli/index.ts serve",
    "start": "node dist/cli/index.js serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.4",
    "bcrypt": "^6.0.0",
    "commander": "^13.1.0",
    "fastify": "^5.3.0",
    "fastify-plugin": "^5.1.0",
    "file-type": "^20.0.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "sharp": "^0.34.1",
    "ssh2-sftp-client": "^12.1.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^24.0.0",
    "@types/sharp": "^0.31.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=24"
  }
}
